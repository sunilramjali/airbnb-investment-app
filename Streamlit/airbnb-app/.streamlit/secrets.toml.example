# Copy this file to .streamlit/secrets.toml and fill in the private key.
# st.connection("snowflake") reads this automatically when running outside Snowflake.
#
# The private key belongs to the read-only service user AIRBNB_APP_SVC.
# Do NOT commit the filled-in secrets.toml — it is git-ignored.

[connections.snowflake]
account = "OHVQGJT-NMB64845"
user = "AIRBNB_APP_SVC"
role = "AIRBNB_APP_PUBLIC_ROLE"
warehouse = "AIRBNB_APP_WH"
database = "AIRBNB_INVESTMENT_DB"
schema = "GOLD"
client_session_keep_alive = true

# Provide the private key ONE of two ways:
#
# (A) File path — for local dev or hosts with a filesystem (self-hosted container, VM):
# private_key_file = "deploy_secrets/rsa_key.p8"
#
# (B) Inline PEM — for hosts with TOML-only secrets (e.g. Streamlit Community Cloud).
#     Paste the full contents of deploy_secrets/rsa_key.p8 including BEGIN/END lines:
# private_key = """
# -----BEGIN PRIVATE KEY-----
# ...
# -----END PRIVATE KEY-----
# """

# Gemini live API key + optional model override.
#
# The app resolves these in this order:
#   1. Snowflake-managed secret (container runtime) — exposed as TOP-LEVEL keys
#      "gemini_api_key" / "gemini_model" via the Streamlit SECRETS binding.
#      Set these up with setup/gemini_external_access.sql (recommended for
#      Streamlit in Snowflake; the key is encrypted, never staged in plaintext).
#   2. This local nested [gemini] table — used when running OUTSIDE Snowflake
#      (e.g. Streamlit Community Cloud). Do NOT commit a real key.
#
# --- Local / Community Cloud form (nested) ---
[gemini]
api_key = "YOUR_GEMINI_API_KEY"
# model = "gemini-3.1-flash"   # optional; app defaults to gemini-3.1-flash-lite

# --- Snowflake-managed form (top-level) — only if you mirror it locally ---
# gemini_api_key = "YOUR_GEMINI_API_KEY"
# gemini_model   = "gemini-3.1-flash"
